listening-port=3478
tls-listening-port=5349
listening-ip=${LISTENING_IP}

relay-ip=${RELAY_IP}
# NAT format: external-ip=<public>/<private>; if direct public IP both are equal
external-ip=${EXTERNAL_IP}/${RELAY_IP}

realm=${REALM}

min-port=${MIN_PORT}
max-port=${MAX_PORT}

# CERT_DIR is the path inside the container to the directory with fullchain.pem / privkey.pem.
# It is set via .env and depends on cert_source (certbot or manual).
cert=${CERT_DIR}/fullchain.pem
pkey=${CERT_DIR}/privkey.pem
no-tlsv1
no-tlsv1_1

# TLS cipher hardening (excludes weak suites)
cipher-list=ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256

# ---- Authentication mode (injected by entrypoint.sh) ----
##AUTH_BLOCK##

# ---- RFC 8656 / WebRTC security ----
fingerprint

# Nonce expires after 1 hour (RFC 8656 §9 recommendation)
stale-nonce=3600

# NOTE: secure-stun is intentionally NOT set.
# FreePBX sends unauthenticated STUN binding requests for ICE checks;
# secure-stun would reject those and break WebRTC connectivity.

no-multicast-peers

# Block RFC 1918, special-use, and IPv4-mapped ranges as relay targets (RFC 8656 §9.1)
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=240.0.0.0-255.255.255.255
denied-peer-ip=::1
denied-peer-ip=fe80::-febf:ffff:ffff:ffff:ffff:ffff:ffff:ffff
denied-peer-ip=fc00::-fdff:ffff:ffff:ffff:ffff:ffff:ffff:ffff
# IPv4-mapped addresses (bypass for RFC 1918 blocking)
denied-peer-ip=::ffff:0.0.0.0-::ffff:255.255.255.255
# NAT64 prefix
denied-peer-ip=64:ff9b::-64:ff9b::ffff:ffff

# DoS protection quotas
user-quota=20
total-quota=100

new-log-timestamp

cli-ip=127.0.0.1
cli-port=5766
