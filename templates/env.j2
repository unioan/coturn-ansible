EXTERNAL_IP={{ external_ip }}
RELAY_IP={{ relay_ip }}
LISTENING_IP={{ listening_ip }}
AUTH_MODE={{ auth_mode }}
TURN_USER={{ turn_user }}
TURN_PASSWORD={{ turn_password }}
REALM={{ realm }}
MIN_PORT={{ min_port }}
MAX_PORT={{ max_port }}

{% if cert_source == 'certbot' %}
# certbot: mount letsencrypt root so symlinks to archive/ resolve inside container
LETSENCRYPT_LIVE_DIR=/etc/letsencrypt
CERT_DIR=/etc/coturn/certs/live/{{ domain }}
{% else %}
# manual: mount the cert directory directly as /etc/coturn/certs
LETSENCRYPT_LIVE_DIR={{ manual_cert_dir }}
CERT_DIR=/etc/coturn/certs
{% endif %}
